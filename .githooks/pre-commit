#!/usr/bin/env bash
# Tokimo pre-commit hook: 自动 fmt staged 文件
# 主仓库与所有 submodule 共用本脚本（通过 core.hooksPath 指向）
# 安装方式: ./scripts/install-hooks.sh

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

mapfile -t STAGED < <(git diff --cached --name-only --diff-filter=ACM)

if [ "${#STAGED[@]}" -eq 0 ]; then
  exit 0
fi

RUST_FILES=()
WEB_FILES=()
for f in "${STAGED[@]}"; do
  [ -f "$f" ] || continue
  case "$f" in
    *.rs)
      RUST_FILES+=("$f")
      ;;
    *.ts|*.tsx|*.js|*.jsx|*.mjs|*.cjs|*.json|*.jsonc|*.css)
      WEB_FILES+=("$f")
      ;;
  esac
done

CHANGED=()

if [ "${#RUST_FILES[@]}" -gt 0 ]; then
  if command -v rustfmt >/dev/null 2>&1; then
    # 向上查找最近的 Cargo.toml 解析 edition；找不到默认 2021
    detect_edition() {
      local dir
      dir="$(cd "$(dirname "$1")" && pwd)"
      while [ "$dir" != "/" ] && [ -n "$dir" ]; do
        if [ -f "$dir/Cargo.toml" ]; then
          local ed
          ed="$(grep -E '^[[:space:]]*edition[[:space:]]*=' "$dir/Cargo.toml" \
                | head -1 | sed -E 's/.*"([^"]+)".*/\1/')"
          if [ -n "$ed" ]; then
            echo "$ed"
            return
          fi
        fi
        dir="$(dirname "$dir")"
      done
      echo "2021"
    }

    declare -A BY_EDITION=()
    for f in "${RUST_FILES[@]}"; do
      ed="$(detect_edition "$f")"
      BY_EDITION["$ed"]+="$f"$'\n'
    done

    for ed in "${!BY_EDITION[@]}"; do
      mapfile -t group < <(printf '%s' "${BY_EDITION[$ed]}")
      printf '\033[0;34m[pre-commit]\033[0m rustfmt (edition %s) %d 个文件\n' "$ed" "${#group[@]}"
      rustfmt --edition "$ed" "${group[@]}"
    done
    CHANGED+=("${RUST_FILES[@]}")
  else
    printf '\033[0;33m[pre-commit]\033[0m 跳过 Rust fmt: 未找到 rustfmt\n' >&2
  fi
fi

if [ "${#WEB_FILES[@]}" -gt 0 ]; then
  BIOME_CMD=""
  if [ -f biome.json ] || [ -f biome.jsonc ]; then
    if command -v pnpm >/dev/null 2>&1 && pnpm exec biome --version >/dev/null 2>&1; then
      BIOME_CMD="pnpm exec biome"
    elif command -v npx >/dev/null 2>&1; then
      BIOME_CMD="npx --no-install biome"
    fi
  fi

  if [ -n "$BIOME_CMD" ]; then
    printf '\033[0;34m[pre-commit]\033[0m biome format %d 个文件\n' "${#WEB_FILES[@]}"
    $BIOME_CMD format --write --no-errors-on-unmatched "${WEB_FILES[@]}" >/dev/null
    CHANGED+=("${WEB_FILES[@]}")
  fi
fi

if [ "${#CHANGED[@]}" -gt 0 ]; then
  git add -- "${CHANGED[@]}"
fi

exit 0
